{
  "name": "@wfh/desktop-agent",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/bundle.cjs --external:screenshot-desktop",
    "build:exe:win": "npm run bundle && pkg dist/bundle.cjs --targets node18-win-x64 --output dist/wfh-desktop-agent.exe --public-packages \"*\"",
    "lint": "node -e \"console.log('No linter configured for desktop-agent yet')\"",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@wfh/shared": "*",
    "dotenv": "^16.6.1",
    "screenshot-desktop": "^1.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.5",
    "pkg": "^5.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "pkg": {
    "assets": [
      "node_modules/screenshot-desktop/lib/**/*",
      "node_modules/screenshot-desktop/vendor/**/*"
    ]
  }
}
